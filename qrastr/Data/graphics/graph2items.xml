	<!--  xsize,ysize для fuzzyitem - дефотные размеры -->
	
	<fuzzyitem id="3" name="BusbarSection" stayalwaysunfixed="1" xmin="2" xmax="1000" ymin="4" ymax="4" xsize="11" ysize="4" offminscale="0.12" cancrossvertical="1" cancrosshorizontal="0">
		<view>
			
			<SetPen arg0="if(scale>2)(if(scale>5)8:4):2"/>		
			<Line arg0="pix(3)" arg1="32" arg2="x*16-pix(3)" arg3="32"/>
			<SetPen arg0="2"/>
		</view>
		<connections count="x*2-2" equipotentialrule="1">
			<connect dx="1+pos" dy="if(bitpos)4:0">
				<Line arg0="16+pos*16" arg1="if(bitpos)40:24" arg2="16+pos*16" arg3="if(bitpos)64:0"/>
				<StopIf arg0="!(scale>2.5)" />
				<FillEllipse arg0="pos*16+16" arg1="32" arg2="16" arg3="16" arg4="0"/>
				<!-- криво работает, заливка косячит, то же самое на прямоугольнике-->
				
			</connect>
		</connections>
	</fuzzyitem>	
	
